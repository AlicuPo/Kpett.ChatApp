{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "JwtSection": {
    "KeyAccess": "YOUR_ACCESS_TOKEN_SECRET",
    "KeyRefres": "YOUR_REFRESH_TOKEN_SECRET",
    "Issuer": "kpett.chatApp",
    "Audience": "kpett.chatApp",
    "AccessTokenExpireMinutes": 5,
    "RefreshTokenExpireDays": 365
  },

  "ConnectionStrings": {
    "KpettChatAppDb": "Server=tcp:YOUR_SERVER,1433;Initial Catalog=YOUR_DATABASE;Persist Security Info=False;User ID=YOUR_USER;Password=YOUR_PASSWORD;",
    "Redis": "OUR_REDIS_HOST:6379"
  },

  "Cors": {
    "AllowedOrigins": [
      "http://your-domin"
    ]
  },

  "CloudinarySettings": {
    "CloudName": "YOUR_CLOUDINARY_CLOUD_NAME",
    "ApiKey": "YOUR_CLOUDINARY_API_KEY",
    "ApiSecret": "YOUR_CLOUDINARY_API_SECRET",
    "NotificationUrl": "https://your-domain.com/api/webhook/cloudinary"
  },

  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "EnableSsl": true,
    "SmtpUsername": "YOUR_GMAIL_ADDRESS",
    "SmtpPassword": "YOUR_GMAIL_APP_PASSWORD",
    "FromEmail": "YOUR_GMAIL_ADDRESS",
    "FromName": "Kpett.ChatApp",
    "PasswordResetOtpExpiryMinutes": 10,
    "PasswordResetOtpLength": 6
  },

  "MediaSettings": {
    "MaxImageSizeBytes": 5242880,
    "MaxVideoSizeBytes": 52428800,
    "AllowedImageExtensions": [ ".jpg", ".jpeg", ".png", ".webp", ".gif" ],
    "AllowedVideoExtensions": [ ".mp4", ".mov", ".avi" ]
  }
}
