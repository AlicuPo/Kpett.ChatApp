API_HTTP_PORT=8080
IMAGE_TAG=latest
BUILD_CONFIGURATION=Release
ASPNETCORE_ENVIRONMENT=Production

ConnectionStrings__KpettChatAppDb=Server=tcp:YOUR_SERVER,1433;Initial Catalog=YOUR_DATABASE;Persist Security Info=False;User ID=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=False;
ConnectionStrings__Redis=YOUR_REDIS_HOST:YOUR_REDIS_PORT,password=YOUR_REDIS_PASSWORD,ssl=False,abortConnect=False

JwtSection__KeyAccess=CHANGE_ME_LONG_ACCESS_SECRET
JwtSection__KeyRefres=CHANGE_ME_LONG_REFRESH_SECRET
JwtSection__Issuer=kpett.chatApp
JwtSection__Audience=kpett.chatApp
JwtSection__AccessTokenExpireMinutes=5
JwtSection__RefreshTokenExpireDays=365

Cors__AllowedOrigins__0=https://your-frontend-domain.com

CloudinarySettings__CloudName=YOUR_CLOUDINARY_CLOUD_NAME
CloudinarySettings__ApiKey=YOUR_CLOUDINARY_API_KEY
CloudinarySettings__ApiSecret=YOUR_CLOUDINARY_API_SECRET
CloudinarySettings__NotificationUrl=

EmailSettings__SmtpHost=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__EnableSsl=true
EmailSettings__SmtpUsername=YOUR_GMAIL_ADDRESS
EmailSettings__SmtpPassword=YOUR_GMAIL_APP_PASSWORD
EmailSettings__FromEmail=YOUR_GMAIL_ADDRESS
EmailSettings__FromName=Kpett.ChatApp

EmailSettings__PasswordResetOtpExpiryMinutes=10
EmailSettings__PasswordResetOtpLength=6
